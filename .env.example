# Docker/Production Paths (used in docker-compose.yml)
SOURCE_PHOTOS_PATH=/path/to/your/source/photos
SORTED_PHOTOS_PATH=/path/to/your/sorted/photos
TRASH_PHOTOS_PATH=/path/to/your/trash/photos
DB_DATA_PATH=./data
PUID=1000
PGID=1000

# General
NODE_ENV=development
APP_PORT=3001
WEB_PORT=5173

# Database
DATABASE_PATH=./data/axissort.db

# Development library paths
SOURCE_ROOT=./dev-library/source
DESTINATION_LEFT=./dev-library/dest-left
DESTINATION_RIGHT=./dev-library/dest-right
DESTINATION_UP=./dev-library/dest-up
DESTINATION_DOWN=./dev-library/dest-down
TRASH_PATH=./dev-library/trash

# Optional Labels (Defaults to tail end of path if empty)
DESTINATION_LEFT_LABEL=
DESTINATION_RIGHT_LABEL=
DESTINATION_UP_LABEL=
DESTINATION_DOWN_LABEL=
DESTINATION_TRASH_LABEL=Trash

# Queue & Back-pressure (Back-end Performance)
# Point where we might show a 'busy' UI indicator.
QUEUE_SOFT_THRESHOLD=25
# Max pending actions allowed before the UI 'pauses' to let the disk catch up.
QUEUE_HARD_THRESHOLD=50
# After a pause, we only resume once the queue has drained back down to this level.
QUEUE_RESUME_THRESHOLD=10
# Number of files to process per batch.
QUEUE_BATCH_SIZE=10
# Max concurrent worker threads (Keep at 1 for most disk-bound workloads).
QUEUE_WORKER_CONCURRENCY=1

# Safety
DRY_RUN_MODE=true

# Interface
# Options: Tinder (2-way), TinderPlus (4-way)
SORT_MODE=Tinder
